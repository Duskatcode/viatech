# ======================================================
# VITATECH — DESARROLLO LOCAL
# Copiar a .env.development y ajustar si hace falta.
# Este archivo NUNCA debe contener credenciales reales de produccion.
# ======================================================

NODE_ENV=development

APP_NAME=Vitatech Maintenance API
APP_VERSION=0.0.1

API_PORT=3000
API_PREFIX=api/v1
SWAGGER_PATH=api/docs
ENABLE_SWAGGER=true

########################
# Base de datos — Postgres local via docker-compose
# ATENCION: si corres la API fuera de Docker (pnpm dev:api), usa
# localhost:${POSTGRES_PORT}. Si corres TODO con docker-compose, el
# servicio 'api' ignora este valor y usa la red interna (db:5432)
# automaticamente — ver docker-compose.yml. Nunca apuntes esto a un
# host externo (Supabase, RDS, etc.) en este archivo.
########################

POSTGRES_DB=biomed_db
POSTGRES_USER=biomed
POSTGRES_PASSWORD=biomed_password
POSTGRES_PORT=5433

DATABASE_URL=postgresql://biomed:biomed_password@localhost:5433/biomed_db

########################
# JWT (valores de ejemplo, no usar en produccion)
########################

JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

########################
# Frontend / CORS
########################

FRONTEND_ORIGIN=http://localhost:5173

########################
# Attachments
########################

ATTACHMENTS_STORAGE_DIR=storage/attachments

########################
# Docker (puertos expuestos al host)
########################

HOST_API_PORT=3001
WEB_PORT=8081

########################
# Web (Vite)
########################

VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_FEEDBACK_EMAIL=
