# Docker local deployment

POSTGRES_DB=biomed
POSTGRES_USER=biomed
POSTGRES_PASSWORD=biomed_password
POSTGRES_PORT=5434

DATABASE_URL="postgresql://postgres.fwuyorsdspgdoxmcbrav:Nf6X3UszBEtmJlul@aws-1-us-east-2.pooler.supabase.com:6543/postgres"

API_PORT=3001
WEB_PORT=8081

# Docker Compose keeps this local compatibility alias. Hosted API services
# should set CORS_ORIGINS directly with a comma-separated allowlist.
FRONTEND_ORIGIN=http://localhost:8081

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

ATTACHMENTS_STORAGE_DIR=/app/storage/attachments

# API docs
# Enable only for local/demo environments. Disable in production.
ENABLE_SWAGGER=true
