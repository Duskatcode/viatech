# ======================================================
# VITATECH — PRODUCCION
# Copiar a .env.production y completar con los valores reales del
# proveedor (Supabase, Railway, etc). NUNCA commitear este archivo con
# valores reales. Este template no contiene ningun secreto real.
# ======================================================

NODE_ENV=production

APP_NAME=Vitatech Maintenance API
APP_VERSION=0.0.1

API_PORT=3000
API_PREFIX=api/v1
SWAGGER_PATH=api/docs
# Swagger deshabilitado por defecto en produccion.
ENABLE_SWAGGER=false

########################
# Base de datos — proveedor gestionado (ej. Supabase)
# Usar SIEMPRE el connection pooler para runtime de la app, nunca la
# conexion directa (ver docs/64-deployment-environment-guide.md).
########################

DATABASE_URL=postgresql://USER:PASSWORD@YOUR-PROJECT.pooler.supabase.com:6543/postgres

# Solo necesario para correr `prisma migrate` desde tu maquina: conexion
# de sesion (IPv4-compatible), NUNCA la conexion directa (ver guia de
# despliegue). No es usada por la app en runtime.
DIRECT_URL=postgresql://USER:PASSWORD@YOUR-PROJECT.pooler.supabase.com:5432/postgres

########################
# JWT — generar secretos reales y unicos para produccion
# (ej. `openssl rand -base64 48`), nunca reutilizar los de desarrollo.
########################

JWT_ACCESS_SECRET=REPLACE_WITH_REAL_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_REAL_SECRET
JWT_ACCESS_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

########################
# Frontend / CORS
########################

FRONTEND_ORIGIN=https://your-production-domain.com

########################
# Attachments
########################

ATTACHMENTS_STORAGE_DIR=/app/storage/attachments

########################
# Web (Vite) — build-time, apunta al dominio real de la API
########################

VITE_API_BASE_URL=https://your-api-domain.com/api/v1
VITE_FEEDBACK_EMAIL=
