generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String             @id @default(cuid())
  name                      String
  email                     String             @unique
  passwordHash              String
  role                      UserRole           @default(VIEWER)
  isActive                  Boolean            @default(true)
  companyId                 String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  refreshTokenHash          String?
  auditLogs                 AuditLog[]
  assignedMaintenanceOrders MaintenanceOrder[] @relation("AssignedMaintenanceOrders")
  createdMaintenanceOrders  MaintenanceOrder[] @relation("CreatedMaintenanceOrders")
  company                   Company?           @relation(fields: [companyId], references: [id])
  memberships               CompanyMembership[] @relation("UserMemberships")
  assignedMemberships       CompanyMembership[] @relation("MembershipAssignedBy")

  @@index([companyId])
  @@index([role])
}

model Company {
  id        String      @id @default(cuid())
  name      String
  nit       String?     @unique
  phone     String?
  email     String?
  address   String?
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  equipment Equipment[]
  sites     Site[]
  users     User[]
  memberships CompanyMembership[]
}

model Site {
  id        String      @id @default(cuid())
  name      String
  address   String?
  city      String?
  isActive  Boolean     @default(true)
  companyId String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  areas     Area[]
  equipment Equipment[]
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberships CompanyMembership[]

  @@index([companyId])
}

model Area {
  id          String      @id @default(cuid())
  name        String
  floor       String?
  description String?
  isActive    Boolean     @default(true)
  siteId      String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  site        Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  equipment   Equipment[]

  @@index([siteId])
}

model Equipment {
  id                String             @id @default(cuid())
  internalCode      String
  name              String
  brand             String?
  model             String?
  serialNumber      String?
  equipmentType     String?
  riskLevel         String?
  status            EquipmentStatus    @default(ACTIVE)
  purchaseDate      DateTime?
  installationDate  DateTime?
  warrantyUntil     DateTime?
  notes             String?
  companyId         String
  siteId            String
  areaId            String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attachments       Attachment[]
  area              Area               @relation(fields: [areaId], references: [id])
  company           Company            @relation(fields: [companyId], references: [id])
  site              Site               @relation(fields: [siteId], references: [id])
  maintenanceOrders MaintenanceOrder[]

  @@unique([companyId, internalCode])
  @@index([companyId])
  @@index([siteId])
  @@index([areaId])
  @@index([status])
}

model MaintenanceOrder {
  id                   String            @id @default(cuid())
  code                 String            @unique
  type                 MaintenanceType
  status               MaintenanceStatus @default(PENDING)
  scheduledDate        DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  description          String?
  diagnosis            String?
  actionsPerformed     String?
  recommendations      String?
  finalEquipmentStatus EquipmentStatus?
  equipmentId          String
  assignedToId         String?
  createdById          String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  attachments          Attachment[]
  assignedTo           User?             @relation("AssignedMaintenanceOrders", fields: [assignedToId], references: [id])
  createdBy            User?             @relation("CreatedMaintenanceOrders", fields: [createdById], references: [id])
  equipment            Equipment         @relation(fields: [equipmentId], references: [id])
  tasks                MaintenanceTask[]

  @@index([equipmentId])
  @@index([assignedToId])
  @@index([createdById])
  @@index([status])
  @@index([type])
}

model MaintenanceTask {
  id          String           @id @default(cuid())
  title       String
  description String?
  isCompleted Boolean          @default(false)
  completedAt DateTime?
  orderId     String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  order       MaintenanceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Attachment {
  id           String            @id @default(cuid())
  type         AttachmentType    @default(OTHER)
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  orderId      String?
  equipmentId  String?
  createdAt    DateTime          @default(now())
  equipment    Equipment?        @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  order        MaintenanceOrder? @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([equipmentId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  oldValue  Json?
  newValue  Json?
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([entityId])
}

// Vincula un usuario (tipicamente TECHNICIAN) a una empresa y, opcionalmente,
// a una sede especifica de esa empresa. Un mismo usuario puede tener varias
// membresias activas simultaneas (distintas empresas/sedes). No se borra al
// revocar: se marca INACTIVE + revokedAt, para conservar el historial de
// ordenes de mantenimiento que el usuario ya completo bajo esa membresia.
model CompanyMembership {
  id           String           @id @default(cuid())
  userId       String
  companyId    String
  siteId       String?
  status       MembershipStatus @default(ACTIVE)
  assignedById String?
  assignedAt   DateTime         @default(now())
  revokedAt    DateTime?
  user         User             @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site         Site?            @relation(fields: [siteId], references: [id], onDelete: SetNull)
  assignedBy   User?            @relation("MembershipAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@index([siteId])
  @@index([status])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TECHNICIAN
  VIEWER
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
}

enum EquipmentStatus {
  ACTIVE
  IN_MAINTENANCE
  OUT_OF_SERVICE
  RETIRED
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
}

enum MaintenanceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AttachmentType {
  PHOTO
  PDF
  DOCUMENT
  SIGNATURE
  OTHER
}
