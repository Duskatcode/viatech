<file path="docker-compose.yml">
services:
  db:
    image: postgres:17-alpine
    container_name: biomed-db
    restart: unless-stopped
    environment:
      POSTGRES_DB: ${POSTGRES_DB:-biomed}
      POSTGRES_USER: ${POSTGRES_USER:-biomed}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-biomed_password}
    ports:
      - "${POSTGRES_PORT:-5434}:5432"
    volumes:
      - biomed_postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-biomed} -d ${POSTGRES_DB:-biomed}"]
      interval: 10s
      timeout: 5s
      retries: 10
  api:
    build:
      context: .
      dockerfile: apps/api/Dockerfile
    container_name: biomed-api
    restart: unless-stopped
    depends_on:
      db:
        condition: service_healthy
    environment:
      NODE_ENV: production
      API_PORT: 3000
      DATABASE_URL: ${DATABASE_URL}
      JWT_ACCESS_SECRET: ${JWT_ACCESS_SECRET:-change-me-access-secret}
      JWT_REFRESH_SECRET: ${JWT_REFRESH_SECRET:-change-me-refresh-secret}
      JWT_ACCESS_EXPIRES_IN_SECONDS: ${JWT_ACCESS_EXPIRES_IN_SECONDS:-900}
      JWT_REFRESH_EXPIRES_IN_SECONDS: ${JWT_REFRESH_EXPIRES_IN_SECONDS:-604800}
      ATTACHMENTS_STORAGE_DIR: ${ATTACHMENTS_STORAGE_DIR:-/app/storage/attachments}
      FRONTEND_ORIGIN: ${FRONTEND_ORIGIN:-http://localhost:8081}
    ports:
      - "${HOST_API_PORT:-3001}:3000"
    volumes:
      - biomed_uploads:/app/storage/attachments
      - biomed_reports:/app/apps/api/reports
  web:
    build:
      context: .
      dockerfile: apps/web/Dockerfile
      args:
        VITE_API_URL: /api/v1
    container_name: biomed-web
    restart: unless-stopped
    depends_on:
      - api
    ports:
      - "${WEB_PORT:-8081}:80"
volumes:
  biomed_postgres_data:
