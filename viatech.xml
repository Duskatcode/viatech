FROM deps AS build

COPY . .

RUN pnpm --filter @vitatech/shared build \
 && pnpm --filter @vitatech/api build

FROM base AS runner

WORKDIR /app

ENV NODE_ENV=production

COPY --from=build /app/package.json ./package.json
